# deploy/Caddyfile
# Replace yourdomain.com with your actual domain before deploying

api.yourdomain.com {
    reverse_proxy localhost:3000
}

pb.yourdomain.com {
    @admin path /_/*
    handle @admin {
        # Uncomment and configure basic auth before exposing to the internet:
        # basicauth admin {
        #   admin JDJhJDE0J...  # bcrypt hash of your password
        # }
        reverse_proxy localhost:8090
    }
    reverse_proxy localhost:8090
}
